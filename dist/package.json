            "dist/nodes/QrCode.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "@types/qrcode": "^1.5.6",
        "eslint": "9.39.4",
        "prettier": "3.8.1",
        "release-it": "19.2.4",
        "typescript": "5.9.3"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    },
    "dependencies": {
        "qrcode": "^1.5.4"
    }
}
