{
    "name": "n8n-nodes-qrcode-victor",
    "version": "0.1.0",
    "description": "QR Code generator node for n8n",
    "license": "MIT",
    "homepage": "",
    "keywords": [
        "n8n-community-node-package"
    ],
    "author": {
        "name": "Victor Montezani",
        "email": "victor_montezani@hotmail.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/victormontezani-oss/n8n-nodes-qrcode.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
